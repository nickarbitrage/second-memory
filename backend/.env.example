# Database (SQLite for local, PostgreSQL for production)
# SQLite: sqlite+aiosqlite:///./meetmind.db
# PostgreSQL: postgresql+asyncpg://postgres:postgres@localhost:5432/meetmind
DATABASE_URL=sqlite+aiosqlite:///./meetmind.db

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Provider (OpenAI-compatible)
# Get a free key at https://freemodel.dev
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# App
APP_NAME=Second Memory
DEBUG=true
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
